# =========================================================
# Variables de entorno — se configuran en el SERVICIO n8n de Railway
# (NO en este repo). Este archivo es solo de referencia.
# =========================================================

# CRÍTICO: desbloquea el acceso a $env dentro de nodos/credenciales de n8n.
# Sin esto, la credencial Postgres y el verify token NO funcionan.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# --- Postgres (referencia al servicio de BD en el mismo proyecto Railway) ---
# Ajusta "Postgres" al nombre real de tu servicio de base de datos.
WA_PGHOST=${{Postgres.PGHOST}}
WA_PGDATABASE=${{Postgres.PGDATABASE}}
WA_PGUSER=${{Postgres.PGUSER}}
WA_PGPASSWORD=${{Postgres.PGPASSWORD}}

# --- WhatsApp / Meta ---
# Token de verificación del webhook (invéntalo; el mismo va en la config de Meta).
WA_VERIFY_TOKEN=cambia-esto-por-un-token-propio
